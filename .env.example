# Supabase configuration (Publik untuk integrasi Auth sisi klien)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Aplikasi
NEXT_PUBLIC_APP_NAME="Nama Perusahaan / Agen"
NEXT_PUBLIC_APP_SHORT_NAME="Nama Pendek Aplikasi"
NEXT_PUBLIC_DEFAULT_LAT=-6.1751
NEXT_PUBLIC_DEFAULT_LNG=106.7650
NEXT_PUBLIC_DEFAULT_ZOOM=13

# Kredensial Rahasia (Sangat Sensitif, Jangan diekspos ke klien)
NEXTAUTH_SECRET=your-random-secret-key-for-auth
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-do-not-share

# SMTP untuk Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM="Nama Pengirim <your-email@gmail.com>"
